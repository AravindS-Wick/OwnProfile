# ─── Portfolio Environment Variables Template ────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* vars are exposed to the browser (safe for public info).
# Server-only vars (no NEXT_PUBLIC_ prefix) stay private.
# ─────────────────────────────────────────────────────────────────────────────

# ── Profile ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PROFILE_NAME=Aravindhan
NEXT_PUBLIC_PROFILE_TITLE=Full Stack Developer
NEXT_PUBLIC_PROFILE_BIO=I'm a full-stack developer obsessed with building things that matter. From pixel-perfect UIs to rock-solid APIs, cloud infrastructure to mobile apps — I run the full stack with high ambition and zero limits.
NEXT_PUBLIC_PROFILE_LOCATION=India
NEXT_PUBLIC_PROFILE_AVAILABLE=true
NEXT_PUBLIC_PROFILE_EMAIL=your@outlook.com
NEXT_PUBLIC_PROFILE_RESUME_URL=/resume.pdf

# ── Social Links ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOCIAL_GITHUB=https://github.com/yourusername
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/in/yourusername
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=

# ── Stats (shown in hero) ─────────────────────────────────────────────────────
NEXT_PUBLIC_STAT_PROJECTS=20+
NEXT_PUBLIC_STAT_TECHNOLOGIES=15+
NEXT_PUBLIC_STAT_CERTIFICATIONS=2
NEXT_PUBLIC_STAT_EXPERIENCE=3+

# ── Theme ─────────────────────────────────────────────────────────────────────
# Options: cyberpunk | forest | mono | sunset
# Controls the default theme on first load (user can override via UI)
NEXT_PUBLIC_DEFAULT_THEME=cyberpunk

# ── Notifications (server-only — never expose to browser) ────────────────────

# Google Apps Script Webhook URL
# Get from: Google Sheet → Extensions → Apps Script → Deploy → Web App
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Telegram Bot Notification
TELEGRAM_BOT_TOKEN=1234567890:ABC-DEFghijklmno-EXAMPLE_TOKEN
TELEGRAM_CHAT_ID=987654321

# Discord Webhook Notification
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Outlook Email Notification (smtp.office365.com)
OUTLOOK_EMAIL=your@outlook.com
OUTLOOK_PASSWORD=your-outlook-password

# CRON Security Secret (min 32 chars)
CRON_SECRET=your-random-secret-minimum-32-characters-long
