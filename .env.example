# ─── Portfolio Environment Variables Template ────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.
# All values below are required for full functionality.
# ────────────────────────────────────────────────────────────────────────────

# Google Apps Script Webhook URL
# Get this from: Google Sheet → Extensions → Apps Script → Deploy → Web App
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Telegram Bot Notification
# Get token: Telegram → @BotFather → /newbot
# Get chat ID: Send a message to your bot, then visit:
#   https://api.telegram.org/bot{YOUR_TOKEN}/getUpdates
TELEGRAM_BOT_TOKEN=1234567890:ABC-DEFghijklmno-EXAMPLE_TOKEN
TELEGRAM_CHAT_ID=987654321

# Discord Webhook Notification
# Get from: Discord server → Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Outlook Email Notification (smtp.office365.com)
# Use your full Outlook/Hotmail email address and password
OUTLOOK_EMAIL=your@outlook.com
OUTLOOK_PASSWORD=your-outlook-password

# CRON Security Secret
# Generate a random string (min 32 chars), e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Add this SAME value to GitHub repo Secrets as CRON_SECRET
CRON_SECRET=your-random-secret-minimum-32-characters-long
